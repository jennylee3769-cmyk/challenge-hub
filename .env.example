# ─── 데이터베이스 ───────────────────────────────────────
# Neon 또는 Supabase PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/challenge_hub?sslmode=require"

# ─── JWT 인증 ───────────────────────────────────────────
JWT_ACCESS_SECRET="your-access-secret-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars"
# Access Token: 1시간, Refresh Token: 30일

# ─── 카카오 OAuth ────────────────────────────────────────
KAKAO_CLIENT_ID="your-kakao-rest-api-key"
KAKAO_CLIENT_SECRET="your-kakao-client-secret"
KAKAO_REDIRECT_URI="http://localhost:3000/api/auth/kakao/callback"

# ─── 구글 OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# ─── 토스페이먼츠 ────────────────────────────────────────
TOSS_CLIENT_KEY="test_ck_..."
TOSS_SECRET_KEY="test_sk_..."
TOSS_WEBHOOK_SECRET="your-webhook-secret"

# ─── 암호화 ──────────────────────────────────────────────
# 개인정보 AES-256-GCM 암호화 키 (32바이트 hex)
ENCRYPTION_KEY="your-32-byte-hex-encryption-key"

# ─── 이미지 스토리지 (Cloudflare R2) ────────────────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="challenge-hub"
R2_PUBLIC_URL="https://cdn.challengehub.kr"

# ─── 이메일 (AWS SES) ────────────────────────────────────
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="ap-northeast-2"
SES_FROM_EMAIL="noreply@challengehub.kr"

# ─── YouTube Data API ────────────────────────────────────
YOUTUBE_API_KEY="your-youtube-data-api-key"

# ─── Redis (Upstash) ─────────────────────────────────────
REDIS_URL="redis://default:password@host:port"

# ─── 앱 설정 ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_TOSS_CLIENT_KEY="test_ck_..."
NODE_ENV="development"
